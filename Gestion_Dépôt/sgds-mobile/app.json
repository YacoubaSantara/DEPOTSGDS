{
  "expo": {
    "name": "SGDS Mobile",
    "slug": "sgds-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a3a5c"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sanke.sgdsmobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "L'application SGDS utilise Face ID pour sécuriser et accélérer votre connexion."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a3a5c"
      },
      "package": "com.sanke.sgdsmobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-local-authentication"
    ]
  }
}
