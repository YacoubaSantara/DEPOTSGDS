# Copier ce fichier en ".env" (même dossier) et remplir les vraies valeurs.
# Ne JAMAIS commiter le fichier ".env" — il est dans .gitignore.

# Adresse Gmail utilisée pour l'envoi (ex: sgds.depot@gmail.com)
EMAIL_HOST_USER=

# Mot de passe d'application Gmail (PAS le mot de passe normal du compte).
# À générer sur https://myaccount.google.com/apppasswords
# (nécessite la validation en 2 étapes activée sur le compte Google).
EMAIL_HOST_PASSWORD=

# Adresse affichée comme expéditeur (souvent identique à EMAIL_HOST_USER)
DEFAULT_FROM_EMAIL=
